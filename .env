# Configuration de la base de données PostgreSQL pour développement local
DATABASE_URL="postgresql://bankuser:securepassword123@localhost:5432/bank_of_blockchain"

# Secret pour la génération des tokens JWT (à changer en production)
JWT_SECRET="supersecretdevelopmentkeythatislongenoughforsigningjwttokens123456"

# Clé API pour l'envoi d'emails (optionnel pour les tests basiques)
RESEND_API_KEY=""

# Port de l'API server (utilisé par artifacts/api-server/src/index.ts)
PORT=3000

# Port du frontend Vite dev server (utilisé par artifacts/bank-of-blockchain/vite.config.ts)
FRONTEND_PORT=5173

# Base path pour Vite (utilisé par artifacts/bank-of-blockchain/vite.config.ts)
BASE_PATH="/"

# Port de l'API server pour le proxy Vite (utilisé par artifacts/bank-of-blockchain/vite.config.ts)
VITE_API_PORT=3000

# Environnement de développement
NODE_ENV=development